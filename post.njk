---
layout: base.njk
---
<article class="paper">
  <header class="paper-header">
    <p class="paper-meta">
      <time datetime="{{ page.date | dateIso }}">{{ page.date | readableDate }}</time>
      {% if author %}<span class="paper-by">· {{ author }}</span>{% endif %}
    </p>
    <h1 class="paper-title">{{ title }}</h1>
    {% if abstract %}
    <p class="paper-abstract-lead">{{ abstract }}</p>
    {% endif %}
  </header>
  <div class="paper-body prose">
    {{ content | safe }}
  </div>
</article>
