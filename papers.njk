---
layout: base.njk
title: Papers
description: All published papers and notes.
permalink: /papers/index.html
---
<section class="page-intro">
  <h1 class="page-title">Papers</h1>
  <p class="page-lead">Everything we have posted, newest first. To add a piece, drop a new Markdown file in <code>src/posts/</code> and push to GitHub.</p>
</section>

<ul class="paper-list paper-list--full">
  {% for post in collections.posts %}
  <li>
    <a class="paper-card" href="{{ post.url | url }}">
      <span class="paper-card-date">{{ post.date | readableDate }}</span>
      <span class="paper-card-title">{{ post.data.title }}</span>
      {% if post.data.abstract %}
      <span class="paper-card-abs">{{ post.data.abstract }}</span>
      {% endif %}
      {% if post.data.author %}
      <span class="paper-card-author">{{ post.data.author }}</span>
      {% endif %}
    </a>
  </li>
  {% else %}
  <li class="empty-state">No papers yet—add one under <code>src/posts/</code>.</li>
  {% endfor %}
</ul>
