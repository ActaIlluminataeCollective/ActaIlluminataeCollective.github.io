---
layout: base.njk
description: Research papers and notes from Arin, Noah, Hershil, and Andrei.
---
<section class="hero">
  <h1 class="hero-title">Quiet research, out in the open</h1>
  <p class="hero-lead">{{ site.tagline }}. We post drafts, preprints, and write-ups we care about—nothing flashy, just the work.</p>
  <p class="hero-cta"><a class="button" href="{{ '/papers/' | url }}">Browse papers</a></p>
</section>

<section class="section">
  <div class="section-head">
    <h2>Latest</h2>
    <a class="section-link" href="{{ '/papers/' | url }}">View all</a>
  </div>
  <ul class="paper-list">
    {% for post in collections.posts | limit(4) %}
    <li>
      <a class="paper-card" href="{{ post.url | url }}">
        <span class="paper-card-date">{{ post.date | readableDate }}</span>
        <span class="paper-card-title">{{ post.data.title }}</span>
        {% if post.data.abstract %}
        <span class="paper-card-abs">{{ post.data.abstract }}</span>
        {% endif %}
        {% if post.data.author %}
        <span class="paper-card-author">{{ post.data.author }}</span>
        {% endif %}
      </a>
    </li>
    {% endfor %}
  </ul>
</section>
